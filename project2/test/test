
#!/usr/bin/env python3

import serial
import time
import math
import threading
import numpy as np


# ============================================================
# 포트 설정
# ============================================================
LIDAR_PORT = "/dev/ttyUSB0"
LIDAR_BAUD = 460800

ARDU_PORT = "/dev/ttyS0"
ARDU_BAUD = 9600


# ============================================================
# 라이다 보정값
# ============================================================
ANGLE_OFFSET_DEG = +1.54
DIST_OFFSET_MM = 0.0
LIDAR_ANGLE_SIGN = -1.0


# ============================================================
# 장애물 0/1 로그 설정
# ============================================================
OBSTACLE_LOG_MIN_ANGLE_DEG = -90.0
OBSTACLE_LOG_MAX_ANGLE_DEG = 90.0
OBSTACLE_LOG_STEP_DEG = 1.0

# 이 거리 안에 라이다 점이 있으면 장애물 1로 판단
OBSTACLE_DETECT_DIST_M = 0.45

# 라이다 노이즈 제거용 최소 거리
OBSTACLE_MIN_DIST_M = 0.05

# 라이다 최대 거리
OBSTACLE_MAX_DIST_M = 2.5

# 라이다 품질 기준
OBSTACLE_MIN_QUALITY = 1

# 장애물 주변을 몇 칸 더 1로 확장할지
# 1이면 감지된 각도 좌우 1도까지 같이 1 처리
OBSTACLE_EXPAND_BINS = 1


# ============================================================
# 회피 판단 각도 구간
# -90도: 오른쪽
#  0도 : 정면
# +90도: 왼쪽
# ============================================================
FRONT_MIN_ANGLE_DEG = -20.0
FRONT_MAX_ANGLE_DEG = +20.0

LEFT_MIN_ANGLE_DEG = +20.0
LEFT_MAX_ANGLE_DEG = +90.0

RIGHT_MIN_ANGLE_DEG = -90.0
RIGHT_MAX_ANGLE_DEG = -20.0

# 정면 구간에서 1이 이 개수 이상이면 정면 장애물로 판단
FRONT_BLOCK_COUNT = 3


# ============================================================
# 모터 명령 설정
# ============================================================
FORWARD_V = 0.15       # 평상시 전진 속도
AVOID_V = 0.08         # 장애물 회피 중 전진 속도
AVOID_W = 0.55         # 장애물 회피 회전 속도

# 양수 w = 왼쪽 회전, 음수 w = 오른쪽 회전 기준
# 만약 실제 로봇이 반대로 돌면 AVOID_W 부호 처리만 바꾸면 됨
DEFAULT_TURN_DIR = +1.0    # 양쪽 비슷하게 막혔을 때 기본 왼쪽 회전

LOOP_DT_S = 0.05
LOG_PERIOD_S = 0.10

SCAN_HOLD_S = 0.30


# ============================================================
# 각도 정규화
# ============================================================
def normalize_angle_deg(angle):
    return (angle + 180.0) % 360.0 - 180.0


# ============================================================
# RPLidar C1 제어 클래스
# ============================================================
class RPLidarC1:
    def __init__(self, port, baud):
        self.ser = serial.Serial(port, baud, timeout=0.1)

        # reset
        self.ser.write(bytes([0xA5, 0x40]))
        time.sleep(2.0)
        self.ser.reset_input_buffer()

        # scan start
        self.ser.write(bytes([0xA5, 0x20]))

        header = self.ser.read(7)
        if len(header) != 7 or header[0] != 0xA5 or header[1] != 0x5A:
            self.ser.close()
            raise RuntimeError("[LIDAR] Response Header Error")

        self.lock = threading.Lock()
        self.latest_scan = None
        self.running = True

        self.thread = threading.Thread(target=self._loop, daemon=True)
        self.thread.start()

    def _loop(self):
        buf_a = []
        buf_d = []
        buf_q = []

        while self.running:
            try:
                data = self.ser.read(5)

                if len(data) != 5:
                    continue

                s_flag = data[0] & 0x01
                s_inv = (data[0] & 0x02) >> 1

                if s_inv != (1 - s_flag):
                    continue

                if (data[1] & 0x01) != 1:
                    continue

                quality = data[0] >> 2
                angle = ((data[1] >> 1) | (data[2] << 7)) / 64.0
                dist = (data[3] | (data[4] << 8)) / 4.0

                # 한 바퀴 scan 완료 시점
                if s_flag == 1 and len(buf_a) > 50:
                    with self.lock:
                        self.latest_scan = (
                            np.array(buf_a, dtype=np.float32),
                            np.array(buf_d, dtype=np.float32),
                            np.array(buf_q, dtype=np.float32),
                        )

                    buf_a = []
                    buf_d = []
                    buf_q = []

                if dist > 0 and quality > 0:
                    buf_a.append(angle)
                    buf_d.append(dist)
                    buf_q.append(quality)

            except (serial.SerialException, OSError) as e:
                print(f"[LIDAR] Serial Error: {e}")
                time.sleep(1.0)

                try:
                    self.ser.reset_input_buffer()
                except Exception:
                    pass

    def get_scan(self):
        with self.lock:
            return self.latest_scan

    def close(self):
        self.running = False

        try:
            # stop scan
            self.ser.write(bytes([0xA5, 0x25]))
        except Exception:
            pass

        time.sleep(0.1)
        self.ser.close()


# ============================================================
# 라이다 scan → 장애물 0/1 배열 변환
# ============================================================
def scan_to_obstacle_bits(scan):
    """
    출력:
    obstacle_string:
        예) 000000000000111111111000000000

    bits:
        numpy array, 0 또는 1

    angles_grid:
        각 bit가 의미하는 각도 배열
    """

    angles_grid = np.arange(
        OBSTACLE_LOG_MIN_ANGLE_DEG,
        OBSTACLE_LOG_MAX_ANGLE_DEG + 0.5 * OBSTACLE_LOG_STEP_DEG,
        OBSTACLE_LOG_STEP_DEG,
        dtype=np.float32,
    )

    bits = np.zeros(len(angles_grid), dtype=np.uint8)

    if scan is None:
        return "".join("0" for _ in bits), bits, angles_grid

    angles, dists, qualities = scan

    # 거리 mm → m
    dist_m = (dists.astype(np.float32) + DIST_OFFSET_MM) / 1000.0

    # 각도 보정
    angle_deg = normalize_angle_deg(angles.astype(np.float32) + ANGLE_OFFSET_DEG)
    angle_deg = LIDAR_ANGLE_SIGN * angle_deg

    # 장애물로 볼 점 필터링
    valid = (
        (dist_m >= OBSTACLE_MIN_DIST_M)
        & (dist_m <= OBSTACLE_DETECT_DIST_M)
        & (dist_m <= OBSTACLE_MAX_DIST_M)
        & (qualities >= OBSTACLE_MIN_QUALITY)
        & (angle_deg >= OBSTACLE_LOG_MIN_ANGLE_DEG)
        & (angle_deg <= OBSTACLE_LOG_MAX_ANGLE_DEG)
    )

    if not valid.any():
        return "".join("0" for _ in bits), bits, angles_grid

    obstacle_angles = angle_deg[valid]

    # 각도를 index로 변환
    bins = np.rint(
        (obstacle_angles - OBSTACLE_LOG_MIN_ANGLE_DEG)
        / OBSTACLE_LOG_STEP_DEG
    ).astype(np.int32)

    bins = bins[(bins >= 0) & (bins < len(bits))]

    # 장애물 표시
    for b in bins:
        start = max(0, b - OBSTACLE_EXPAND_BINS)
        end = min(len(bits), b + OBSTACLE_EXPAND_BINS + 1)
        bits[start:end] = 1

    obstacle_string = "".join("1" if b else "0" for b in bits)

    return obstacle_string, bits, angles_grid


# ============================================================
# 특정 각도 구간의 1 개수 계산
# ============================================================
def count_bits_in_angle_range(bits, angles_grid, min_angle, max_angle):
    mask = (angles_grid >= min_angle) & (angles_grid <= max_angle)

    if not mask.any():
        return 0

    return int(np.sum(bits[mask]))


# ============================================================
# 0/1 장애물 배열 기반 단순 회피 제어
# ============================================================
def choose_motor_cmd(bits, angles_grid):
    """
    정면에 장애물이 없으면 직진
    정면에 장애물이 있으면 왼쪽/오른쪽 중 1이 적은 방향으로 회전
    """

    front_count = count_bits_in_angle_range(
        bits,
        angles_grid,
        FRONT_MIN_ANGLE_DEG,
        FRONT_MAX_ANGLE_DEG,
    )

    left_count = count_bits_in_angle_range(
        bits,
        angles_grid,
        LEFT_MIN_ANGLE_DEG,
        LEFT_MAX_ANGLE_DEG,
    )

    right_count = count_bits_in_angle_range(
        bits,
        angles_grid,
        RIGHT_MIN_ANGLE_DEG,
        RIGHT_MAX_ANGLE_DEG,
    )

    front_blocked = front_count >= FRONT_BLOCK_COUNT

    if not front_blocked:
        v = FORWARD_V
        w = 0.0
        mode = "FORWARD"

    else:
        v = AVOID_V

        # 왼쪽이 더 비어 있으면 왼쪽 회전
        if left_count < right_count:
            w = +AVOID_W
            mode = "AVOID_LEFT"

        # 오른쪽이 더 비어 있으면 오른쪽 회전
        elif right_count < left_count:
            w = -AVOID_W
            mode = "AVOID_RIGHT"

        # 양쪽 비슷하면 기본 방향으로 회전
        else:
            w = DEFAULT_TURN_DIR * AVOID_W

            if DEFAULT_TURN_DIR > 0:
                mode = "AVOID_LEFT_DEFAULT"
            else:
                mode = "AVOID_RIGHT_DEFAULT"

    info = {
        "front_count": front_count,
        "left_count": left_count,
        "right_count": right_count,
        "front_blocked": front_blocked,
        "mode": mode,
    }

    return float(v), float(w), info


# ============================================================
# Arduino 모터 명령 전송
# ============================================================
def send_vw(ardu, v, w):
    """
    Arduino로 속도 명령 전송

    형식:
    V0.150,0.000
    """
    cmd = f"V{v:.3f},{w:.3f}\n"
    ardu.write(cmd.encode())


def stop_motor(ardu):
    """
    Arduino 정지 명령
    """
    ardu.write(b"S\n")


# ============================================================
# main
# ============================================================
def main():
    lidar = None
    ardu = None

    try:
        print("[INFO] Opening Arduino serial...")
        ardu = serial.Serial(ARDU_PORT, ARDU_BAUD, timeout=0.1)
        time.sleep(1.0)

        print("[INFO] Opening RPLidar C1...")
        lidar = RPLidarC1(LIDAR_PORT, LIDAR_BAUD)

        print("[INFO] Warming up...")
        stop_motor(ardu)
        time.sleep(2.0)

        print("[INFO] Ready.")
        print("[INFO] Press Enter to start.")
        input()

        print("[INFO] Go!!")
        print("[INFO] Log format: 0 = no obstacle, 1 = obstacle")
        print("[INFO] -90deg = right, 0deg = front, +90deg = left")
        print("[INFO] Press Ctrl+C to stop.")

        last_scan_ok_time = 0.0
        last_log_time = 0.0

        while True:
            now = time.time()

            scan = lidar.get_scan()

            if scan is None:
                # scan이 너무 오래 없으면 안전 정지
                if now - last_scan_ok_time > SCAN_HOLD_S:
                    stop_motor(ardu)

                time.sleep(LOOP_DT_S)
                continue

            last_scan_ok_time = now

            obstacle_string, bits, angles_grid = scan_to_obstacle_bits(scan)

            v, w, info = choose_motor_cmd(bits, angles_grid)

            send_vw(ardu, v, w)

            # 사용자가 원한 0/1 형식 로그 출력
            if now - last_log_time >= LOG_PERIOD_S:
                print(obstacle_string)

                # 디버그가 필요하면 아래 주석 해제
                # print(
                #     f"{obstacle_string} "
                #     f"mode={info['mode']} "
                #     f"v={v:.2f} w={w:.2f} "
                #     f"F={info['front_count']} "
                #     f"L={info['left_count']} "
                #     f"R={info['right_count']}"
                # )

                last_log_time = now

            time.sleep(LOOP_DT_S)

    except KeyboardInterrupt:
        print("\n[INFO] KeyboardInterrupt")

    finally:
        print("[INFO] Stopping motor...")

        if ardu is not None:
            try:
                stop_motor(ardu)
                time.sleep(0.2)
                ardu.close()
            except Exception:
                pass

        if lidar is not None:
            try:
                lidar.close()
            except Exception:
                pass

        print("[INFO] Shutdown complete.")


if __name__ == "__main__":
    main()
