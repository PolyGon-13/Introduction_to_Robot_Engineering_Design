#!/usr/bin/env python3

import serial
import time
import threading
import numpy as np
import matplotlib.pyplot as plt


# =========================
# 라이다 설정
# =========================

LIDAR_PORT = "/dev/ttyUSB0"
LIDAR_BAUD = 460800

ANGLE_OFFSET_DEG = +1.54
DIST_OFFSET_MM = 0.0
LIDAR_ANGLE_SIGN = -1.0

MIN_LIDAR_DIST_M = 0.05
MAX_LIDAR_DIST_M = 2.0
MIN_QUALITY = 1

# 화면 업데이트 속도
DISPLAY_SLEEP_S = 0.005       # 작을수록 화면 갱신 빠름
PUBLISH_INTERVAL_S = 0.02     # 라이다 데이터 갱신 주기, 0.02 = 약 50Hz


def normalize_angle_deg(angle):
    return (angle + 180.0) % 360.0 - 180.0


class RPLidarC1:
    def __init__(self, port, baud):
        self.ser = serial.Serial(port, baud, timeout=0.01)

        self.ser.write(bytes([0xA5, 0x40]))
        time.sleep(2.0)
        self.ser.reset_input_buffer()

        self.ser.write(bytes([0xA5, 0x20]))
        header = self.ser.read(7)

        if len(header) != 7 or header[0] != 0xA5 or header[1] != 0x5A:
            self.ser.close()
            raise RuntimeError("[LIDAR] Response Header Error")

        self.lock = threading.Lock()
        self.latest_scan = None
        self.running = True

        self.thread = threading.Thread(target=self._loop, daemon=True)
        self.thread.start()

    def _publish_scan(self, buf_a, buf_d, buf_q):
        if len(buf_a) < 10:
            return

        with self.lock:
            self.latest_scan = (
                np.array(buf_a, dtype=np.float32),
                np.array(buf_d, dtype=np.float32),
                np.array(buf_q, dtype=np.float32),
            )

    def _loop(self):
        buf_a, buf_d, buf_q = [], [], []
        last_publish = time.time()

        while self.running:
            try:
                data = self.ser.read(5)

                if len(data) != 5:
                    continue

                s_flag = data[0] & 0x01
                s_inv = (data[0] & 0x02) >> 1

                if s_inv != (1 - s_flag):
                    continue

                if (data[1] & 0x01) != 1:
                    continue

                quality = data[0] >> 2
                angle = ((data[1] >> 1) | (data[2] << 7)) / 64.0
                dist = (data[3] | (data[4] << 8)) / 4.0

                # 한 바퀴가 새로 시작되면 기존 버퍼 초기화
                if s_flag == 1 and len(buf_a) > 50:
                    self._publish_scan(buf_a, buf_d, buf_q)
                    buf_a, buf_d, buf_q = [], [], []

                if dist > 0 and quality >= MIN_QUALITY:
                    buf_a.append(angle)
                    buf_d.append(dist)
                    buf_q.append(quality)

                # 한 바퀴를 다 기다리지 않고 중간 데이터도 계속 publish
                now = time.time()
                if now - last_publish >= PUBLISH_INTERVAL_S:
                    self._publish_scan(buf_a, buf_d, buf_q)
                    last_publish = now

            except (serial.SerialException, OSError) as e:
                print(f"[LIDAR] Serial Error: {e}")
                time.sleep(0.5)
                try:
                    self.ser.reset_input_buffer()
                except Exception:
                    pass

    def get_scan(self):
        with self.lock:
            return self.latest_scan

    def close(self):
        self.running = False

        try:
            self.ser.write(bytes([0xA5, 0x25]))
        except Exception:
            pass

        time.sleep(0.1)
        self.ser.close()


def scan_to_xy(scan):
    if scan is None:
        return np.empty((0, 2), dtype=np.float32)

    angles, dists, qualities = scan

    dist_m = (dists.astype(np.float32) + DIST_OFFSET_MM) / 1000.0

    angle_deg = normalize_angle_deg(angles.astype(np.float32) + ANGLE_OFFSET_DEG)
    angle_deg = LIDAR_ANGLE_SIGN * angle_deg

    mask = (
        (dist_m >= MIN_LIDAR_DIST_M)
        & (dist_m <= MAX_LIDAR_DIST_M)
        & (qualities >= MIN_QUALITY)
    )

    if not mask.any():
        return np.empty((0, 2), dtype=np.float32)

    dist_m = dist_m[mask]
    angle_rad = np.deg2rad(angle_deg[mask])

    x = dist_m * np.cos(angle_rad)
    y = dist_m * np.sin(angle_rad)

    return np.column_stack((x, y)).astype(np.float32)


def main():
    print("[INFO] Fast Lidar Visualizer Start")
    print("[INFO] Max distance = 2.0 m")
    print("[INFO] Press Ctrl+C or close window to stop.")

    lidar = RPLidarC1(LIDAR_PORT, LIDAR_BAUD)

    plt.ion()

    fig, ax = plt.subplots(figsize=(7, 7))

    # scatter보다 plot marker가 훨씬 빠름
    line, = ax.plot([], [], linestyle="", marker=".", markersize=2)

    # 로봇 위치
    ax.plot([0], [0], marker="o", markersize=8)

    # 전방 화살표
    ax.arrow(
        0,
        0,
        0.35,
        0,
        head_width=0.06,
        head_length=0.08,
        length_includes_head=True,
    )

    ax.set_title("Fast RPLidar Visualizer - Max 2m")
    ax.set_xlabel("X forward [m]")
    ax.set_ylabel("Y left/right [m]")

    ax.set_xlim(-2.1, 2.1)
    ax.set_ylim(-2.1, 2.1)
    ax.set_aspect("equal", adjustable="box")
    ax.grid(True)

    fig.canvas.draw()

    # blit용 배경 저장
    use_blit = fig.canvas.supports_blit
    background = None

    if use_blit:
        background = fig.canvas.copy_from_bbox(ax.bbox)

    last_print = time.time()

    try:
        while plt.fignum_exists(fig.number):
            scan = lidar.get_scan()
            points = scan_to_xy(scan)

            if len(points) > 0:
                line.set_data(points[:, 0], points[:, 1])
            else:
                line.set_data([], [])

            if use_blit:
                fig.canvas.restore_region(background)
                ax.draw_artist(line)
                fig.canvas.blit(ax.bbox)
                fig.canvas.flush_events()
            else:
                fig.canvas.draw_idle()
                fig.canvas.flush_events()

            if time.time() - last_print > 0.5:
                print(f"[SCAN] points={len(points)}")
                last_print = time.time()

            time.sleep(DISPLAY_SLEEP_S)

    except KeyboardInterrupt:
        print("\n[INFO] KeyboardInterrupt")

    finally:
        lidar.close()
        plt.close(fig)
        print("[INFO] Shutdown complete.")


if __name__ == "__main__":
    main()
