#!/usr/bin/env python3

import serial
import time
import threading
import math
import numpy as np



# =========================
# 통신 규격 유지
# =========================
LIDAR_PORT = "/dev/ttyUSB0"
LIDAR_BAUD = 460800

ARDU_PORT = "/dev/ttyS0"
ARDU_BAUD = 9600

# =========================
# 라이다 보정값 유지
# =========================
ANGLE_OFFSET_DEG = +1.54
DIST_OFFSET_MM = 0.0
LIDAR_ANGLE_SIGN = -1.0

# 좌표계:
# +각도 / +y = 좌측
# -각도 / -y = 우측

# =========================
# 라이다 필터 설정
# =========================
MIN_LIDAR_DIST_M = 0.05
MAX_LIDAR_DIST_M = 2.5
MIN_QUALITY = 1

LOOP_DT_S = 0.05
SCAN_HOLD_S = 0.30

# =========================
# 주행 파라미터
# =========================
BASE_V = 0.18              # 직진 속도 고정

# =========================
# 장애물 회피 파라미터
# =========================
FRONT_SAFE_DIST = 0.60     # 60cm보다 멀면 w = 0
FRONT_WARN_DIST = 0.40     # 로그/모드 구분용
FRONT_DANGER_DIST = 0.20   # 15cm 이하이면 abs(w) = 0.90

FRONT_ANGLE_DEG = 25       # 정면 판단 각도: -25도 ~ +25도
SIDE_MIN_DEG = 30          # 좌우 판단 시작 각도
SIDE_MAX_DEG = 90          # 좌우 판단 끝 각도

# =========================
# 거리 비례 회피 w 파라미터
# =========================
MAX_AVOID_W = 0.90         # 회피 w 최대값, 절대값 기준 0~0.90
MIN_AVOID_W = 0.00         # 완전 비례 방식

# =========================
# 회전 변화량 제한
# =========================
W_RATE_LIMIT = 0.30        # 일반 상황에서 w 변화량 제한
W_RATE_LIMIT_URGENT = 0.50 # 급한 상황에서 w 변화량 제한

# =========================
# 처음 방향 복귀 파라미터
# 현재 코드에서는 front > 60cm일 때 w = 0으로 만들기 때문에
# 안전 구간에서는 heading_w를 사용하지 않음
# =========================
INITIAL_HEADING_RAD = 0.0
robot_heading = 0.0

HEADING_KP = 0.95
HEADING_MAX_W = 0.35
HEADING_DEADBAND_RAD = math.radians(2.0)

# =========================
# 회피 방향 선택 파라미터
# =========================
SIDE_OPTION_DIST = 0.28
AVOID_LOOKAHEAD_S = 0.70
HEADING_CHOICE_MARGIN_RAD = math.radians(3.0)


# =========================
# RPLidar C1 통신 드라이버
# =========================
class RPLidarC1:
    def __init__(self, port, baud):
        self.ser = serial.Serial(port, baud, timeout=0.1)

        # RESET
        self.ser.write(bytes([0xA5, 0x40]))
        time.sleep(2.0)
        self.ser.reset_input_buffer()

        # SCAN
        self.ser.write(bytes([0xA5, 0x20]))

        header = self.ser.read(7)
        if len(header) != 7 or header[0] != 0xA5 or header[1] != 0x5A:
            self.ser.close()
            raise RuntimeError("[LIDAR] Response Header Error")

        self.lock = threading.Lock()
        self.latest_scan = None
        self.running = True

        self.thread = threading.Thread(target=self._loop, daemon=True)
        self.thread.start()

    def _loop(self):
        buf_a, buf_d, buf_q = [], [], []

        while self.running:
            try:
                data = self.ser.read(5)

                if len(data) != 5:
                    continue

                s_flag = data[0] & 0x01
                s_inv = (data[0] & 0x02) >> 1

                # 시작 플래그 검증
                if s_inv != (1 - s_flag):
                    continue

                # 두 번째 바이트 bit0 검증
                if (data[1] & 0x01) != 1:
                    continue

                quality = data[0] >> 2
                angle = ((data[1] >> 1) | (data[2] << 7)) / 64.0
                dist = (data[3] | (data[4] << 8)) / 4.0

                # 한 바퀴 스캔 종료 시 최신 스캔 저장
                if s_flag == 1 and len(buf_a) > 50:
                    with self.lock:
                        self.latest_scan = (
                            np.array(buf_a, dtype=np.float32),
                            np.array(buf_d, dtype=np.float32),
                            np.array(buf_q, dtype=np.float32)
                        )

                    buf_a, buf_d, buf_q = [], [], []

                if dist > 0 and quality > 0:
                    buf_a.append(angle)
                    buf_d.append(dist)
                    buf_q.append(quality)

            except (serial.SerialException, OSError) as e:
                print(f"[LIDAR] Serial Error: {e}")
                time.sleep(1.0)

                try:
                    self.ser.reset_input_buffer()
                except:
                    pass

    def get_scan(self):
        with self.lock:
            return self.latest_scan

    def close(self):
        self.running = False

        try:
            # STOP
            self.ser.write(bytes([0xA5, 0x25]))
        except:
            pass

        time.sleep(0.1)
        self.ser.close()


# =========================
# 각도 정규화
# =========================
def normalize_angle_deg(angle):
    return (angle + 180.0) % 360.0 - 180.0


def normalize_angle_rad(angle):
    return math.atan2(math.sin(angle), math.cos(angle))


# =========================
# 현재 방향 추정
# =========================
def update_heading_by_w(w, dt):
    global robot_heading

    robot_heading += w * dt
    robot_heading = normalize_angle_rad(robot_heading)


# =========================
# 처음 방향으로 복귀하기 위한 w 계산
# 현재 choose_avoidance_cmd에서는 안전 구간에 w=0을 직접 적용하므로
# 이 함수는 회피 방향 선택 예측용으로만 유지
# =========================
def compute_heading_return_w():
    heading_error = normalize_angle_rad(INITIAL_HEADING_RAD - robot_heading)

    if abs(heading_error) < HEADING_DEADBAND_RAD:
        return 0.0, heading_error

    heading_w = HEADING_KP * heading_error
    heading_w = float(np.clip(heading_w, -HEADING_MAX_W, HEADING_MAX_W))

    return heading_w, heading_error


# =========================
# 전방 장애물 거리 기반 비례 회피 w 계산
# =========================
def compute_proportional_avoid_w(front):
    """
    front 거리에 따라 회피 w 절대값을 0.0 ~ 0.90 범위로 비례 계산.

    front > 0.60m:
        abs_w = 0.0

    0.15m < front <= 0.60m:
        front가 가까워질수록 abs_w가 선형 증가

    front <= 0.15m:
        abs_w = 0.90
    """

    # 60cm보다 멀면 회전 없음
    if front > FRONT_SAFE_DIST:
        return 0.0

    # 15cm 이하이면 최대 회피
    if front <= FRONT_DANGER_DIST:
        return MAX_AVOID_W

    # 15cm ~ 60cm 사이에서 비례 계산
    ratio = (FRONT_SAFE_DIST - front) / max(
        1e-6,
        FRONT_SAFE_DIST - FRONT_DANGER_DIST
    )

    ratio = float(np.clip(ratio, 0.0, 1.0))

    abs_w = ratio * MAX_AVOID_W

    if abs_w > 0.0:
        abs_w = max(abs_w, MIN_AVOID_W)

    abs_w = float(np.clip(abs_w, 0.0, MAX_AVOID_W))

    return abs_w


# =========================
# 회피 방향 선택 함수
# 회피 방향 자체를 처음 로봇 앞 방향에 가까워지는 쪽으로 선택
# =========================
def choose_initial_front_avoid_w(left, right, abs_w):
    """
    회피 방향 선택 함수.

    목표:
        전방 장애물이 있을 때,
        처음 로봇 앞 방향에 더 가까워지는 회피 방향을 선택.

    단, 한쪽만 회피 가능하면 충돌 방지를 위해 그 방향을 우선함.

    w 부호:
        +w = 좌회전
        -w = 우회전
    """

    left_w = abs_w
    right_w = -abs_w

    left_available = left >= SIDE_OPTION_DIST
    right_available = right >= SIDE_OPTION_DIST

    # 1. 왼쪽만 회피 가능한 경우
    if left_available and not right_available:
        return left_w, "LEFT_ONLY"

    # 2. 오른쪽만 회피 가능한 경우
    if right_available and not left_available:
        return right_w, "RIGHT_ONLY"

    # 3. 좌우 둘 다 가능하면 처음 방향에 더 가까워지는 쪽 선택
    if left_available and right_available:
        pred_heading_left = normalize_angle_rad(
            robot_heading + left_w * AVOID_LOOKAHEAD_S
        )

        pred_heading_right = normalize_angle_rad(
            robot_heading + right_w * AVOID_LOOKAHEAD_S
        )

        left_err = abs(
            normalize_angle_rad(INITIAL_HEADING_RAD - pred_heading_left)
        )

        right_err = abs(
            normalize_angle_rad(INITIAL_HEADING_RAD - pred_heading_right)
        )

        if left_err + HEADING_CHOICE_MARGIN_RAD < right_err:
            return left_w, "LEFT_TO_INITIAL_FRONT"

        elif right_err + HEADING_CHOICE_MARGIN_RAD < left_err:
            return right_w, "RIGHT_TO_INITIAL_FRONT"

        else:
            # 처음 방향 기준으로 둘 다 비슷하면 더 넓은 쪽 선택
            if left >= right:
                return left_w, "LEFT_MORE_OPEN"
            else:
                return right_w, "RIGHT_MORE_OPEN"

    # 4. 좌우 둘 다 기준상 애매하면 더 넓은 쪽으로 회피
    if left >= right:
        return left_w, "LEFT_WIDER"
    else:
        return right_w, "RIGHT_WIDER"


# =========================
# w 변화량 제한
# =========================
def rate_limit_w(prev_w, target_w, urgent=False):
    limit = W_RATE_LIMIT_URGENT if urgent else W_RATE_LIMIT

    delta = target_w - prev_w

    if delta > limit:
        delta = limit
    elif delta < -limit:
        delta = -limit

    return prev_w + delta


# =========================
# 라이다 스캔을 x, y 점으로 변환
# =========================
def lidar_scan_to_points(scan):
    if scan is None:
        return np.empty((0, 2), dtype=np.float32)

    angles, dists, qualities = scan

    # mm -> m 변환
    dist_m = (dists.astype(np.float32) + DIST_OFFSET_MM) / 1000.0

    # 각도 보정
    angle_deg = normalize_angle_deg(
        angles.astype(np.float32) + ANGLE_OFFSET_DEG
    )

    # 좌우 방향 보정
    angle_deg = LIDAR_ANGLE_SIGN * angle_deg

    # 유효한 라이다 값만 사용
    mask = (
        (dist_m >= MIN_LIDAR_DIST_M) &
        (dist_m <= MAX_LIDAR_DIST_M) &
        (qualities >= MIN_QUALITY)
    )

    if not mask.any():
        return np.empty((0, 2), dtype=np.float32)

    dist_m = dist_m[mask]
    angle_rad = np.deg2rad(angle_deg[mask])

    # 극좌표 -> 직교좌표
    x = dist_m * np.cos(angle_rad)
    y = dist_m * np.sin(angle_rad)

    # 뒤쪽 점 제거, 앞쪽만 사용
    front_mask = x > 0.0

    if not front_mask.any():
        return np.empty((0, 2), dtype=np.float32)

    points = np.column_stack((x[front_mask], y[front_mask])).astype(np.float32)

    return points


# =========================
# 특정 각도 구간의 가장 가까운 거리 계산
# =========================
def sector_min_distance(points, min_deg, max_deg):
    if len(points) == 0:
        return MAX_LIDAR_DIST_M

    x = points[:, 0]
    y = points[:, 1]

    dist = np.sqrt(x ** 2 + y ** 2)
    angle_deg = np.degrees(np.arctan2(y, x))

    mask = (angle_deg >= min_deg) & (angle_deg <= max_deg)

    if not mask.any():
        return MAX_LIDAR_DIST_M

    return float(np.min(dist[mask]))


# =========================
# 장애물 회피 알고리즘
# v는 항상 0.18 고정
# w만 변경해서 회피
# =========================
def choose_avoidance_cmd(points, prev_w):
    front = sector_min_distance(
        points,
        -FRONT_ANGLE_DEG,
        FRONT_ANGLE_DEG
    )

    left = sector_min_distance(
        points,
        SIDE_MIN_DEG,
        SIDE_MAX_DEG
    )

    right = sector_min_distance(
        points,
        -SIDE_MAX_DEG,
        -SIDE_MIN_DEG
    )

    # 직진 속도는 무조건 고정
    v = BASE_V

    heading_w, heading_error = compute_heading_return_w()

    # -------------------------
    # 1. 전방 장애물이 60cm보다 멀면 w = 0
    # -------------------------
    if front > FRONT_SAFE_DIST:
        target_w = 0.0
        mode = "FRONT_CLEAR_W_ZERO"
        urgent = False
        abs_w = 0.0

    # -------------------------
    # 2. 전방 장애물이 15cm ~ 60cm 사이 또는 15cm 이하
    #    → front 거리에 비례해서 회피 w 계산
    # -------------------------
    else:
        abs_w = compute_proportional_avoid_w(front)

        target_w, avoid_mode = choose_initial_front_avoid_w(
            left,
            right,
            abs_w
        )

        if front > FRONT_WARN_DIST:
            mode = "AVOID_PROP_" + avoid_mode
            urgent = False
        elif front > FRONT_DANGER_DIST:
            mode = "STRONG_PROP_" + avoid_mode
            urgent = True
        else:
            mode = "MAX_PROP_" + avoid_mode
            urgent = True

    # =========================
    # 회전 변화량 제한 적용
    # 단, front > 60cm이면 사용자가 요청한 대로 실제 w도 바로 0으로 만듦
    # =========================
    if front > FRONT_SAFE_DIST:
        w = 0.0
    else:
        w = rate_limit_w(prev_w, target_w, urgent)

    info = {
        "front": front,
        "left": left,
        "right": right,
        "abs_w": abs_w,
        "target_w": target_w,
        "heading_w": heading_w,
        "heading_error": heading_error,
        "robot_heading": robot_heading,
        "mode": mode,
        "urgent": urgent
    }

    return v, w, info


# =========================
# 메인 코드
# =========================
def main():
    global robot_heading

    lidar = RPLidarC1(LIDAR_PORT, LIDAR_BAUD)
    ardu = serial.Serial(ARDU_PORT, ARDU_BAUD, timeout=0.1)

    print("[INFO] Warming up...")
    time.sleep(2.0)

    def send_vw(v, w):
        # 기존 통신 규격 유지
        # 예: V0.180,-0.650\n
        msg = f"V{v:.3f},{w:.3f}\n"
        ardu.write(msg.encode())

    def stop():
        # 기존 정지 명령 유지
        ardu.write(b"S\n")

    stop()

    print("[INFO] Start LiDAR obstacle avoidance")
    print("[INFO] v is fixed at 0.18")
    print("[INFO] if front > 0.60m, w = 0")
    print("[INFO] if 0.15m < front <= 0.60m, abs(w) is proportional")
    print("[INFO] if front <= 0.15m, abs(w) = 0.90")
    print("[INFO] Press Ctrl+C to stop")

    robot_heading = 0.0

    last_scan_ok_time = time.time()
    last_w = 0.0
    last_log_time = 0.0
    last_loop_time = time.time()

    try:
        while True:
            now = time.time()
            dt = now - last_loop_time
            last_loop_time = now

            # dt가 너무 커지는 것 방지
            dt = max(0.0, min(dt, 0.20))

            # 이전 w 명령 기준으로 현재 방향 추정
            update_heading_by_w(last_w, dt)

            scan = lidar.get_scan()

            # 라이다 스캔이 없는 경우
            if scan is None:
                # 잠깐 끊기면 마지막 w 유지하면서 v=0.18
                if time.time() - last_scan_ok_time < SCAN_HOLD_S:
                    send_vw(BASE_V, last_w)
                else:
                    # 스캔이 오래 없으면 안전상 정지
                    stop()
                    last_w = 0.0

                time.sleep(LOOP_DT_S)
                continue

            last_scan_ok_time = time.time()

            points = lidar_scan_to_points(scan)

            v, w, info = choose_avoidance_cmd(points, last_w)

            # v는 항상 0.18
            send_vw(BASE_V, w)

            last_w = w

            if time.time() - last_log_time > 0.25:
                print(
                    f"[AVOID] mode={info['mode']} "
                    f"v={BASE_V:.2f} "
                    f"w={w:.2f} "
                    f"abs_w={info['abs_w']:.2f} "
                    f"target_w={info['target_w']:.2f} "
                    f"heading={math.degrees(info['robot_heading']):.1f}deg "
                    f"head_err={math.degrees(info['heading_error']):.1f}deg "
                    f"front={info['front']:.2f} "
                    f"left={info['left']:.2f} "
                    f"right={info['right']:.2f} "
                    f"pts={len(points)}"
                )

                last_log_time = time.time()

            time.sleep(LOOP_DT_S)

    except KeyboardInterrupt:
        print("\n[INFO] KeyboardInterrupt")

    finally:
        stop()
        time.sleep(0.2)

        try:
            ardu.close()
        except:
            pass

        try:
            lidar.close()
        except:
            pass

        print("[INFO] Shutdown complete")


if __name__ == "__main__":
    main()
